{
	"name": "Cognitive Edge AI",
	"build": {
		"context": "..",
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"installTools": true,
			"installJupyterlab": true,
			"version": "3.13"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter",
				"GitLab.gitlab-workflow",
				"charliermarsh.ruff"
			]
		}
	},
	"postCreateCommand": "pip install -r requirements.txt"
}